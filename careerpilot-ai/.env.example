# ── CareerPilot AI — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Required for Phase 2+. Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use. Defaults to gemini-3.5-flash if not set.
# Verified working alternatives: gemini-3.1-flash-lite, gemini-3-flash-preview
GEMINI_MODEL=gemini-3.5-flash

# ── Server ────────────────────────────────────────────────────────────────────
# Port the FastAPI server listens on. Defaults to 8080.
PORT=8080
