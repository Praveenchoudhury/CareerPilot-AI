# ── CareerPilot AI — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Required for Phase 2+. Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use. Defaults to gemini-2.5-flash-preview-05-20 if not set.
# Other options: gemini-2.0-flash, gemini-1.5-flash
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# ── Server ────────────────────────────────────────────────────────────────────
# Port the FastAPI server listens on. Defaults to 8080.
PORT=8080
